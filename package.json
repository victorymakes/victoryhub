{
  "name": "tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-page-metadata": "node scripts/page-metadata-generator.mjs",
    "dev": "npm run generate-page-metadata && next dev",
    "build": "npm run generate-page-metadata && next build",
    "start": "npm run generate-page-metadata && next start",
    "lint": "next lint",
    "format": "prettier . --write",
    "cf:login": "wrangler login",
    "cf:preview": "npm run generate-page-metadata && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run generate-page-metadata && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
